APP_NAME=Knowledge Intelligence Platform
APP_ENV=dev
LOG_LEVEL=INFO

ROOT_PATH=Knowledge-Base
MAX_FILE_SIZE_MB=50
SUPPORTED_EXTENSIONS=.pdf,.docx,.pptx,.txt,.md,.yaml,.yml,.eml,.sh,.toml

CHROMA_PERSIST_DIR=./chroma_store
CHROMA_COLLECTION=knowledge_base

EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024
# auto = use CUDA GPU (FP16) when available, else CPU. Force with "cuda" / "cpu".
EMBEDDING_DEVICE=auto

CHUNK_BREAKPOINT_THRESHOLD_TYPE=percentile
CHUNK_BREAKPOINT_THRESHOLD_AMOUNT=80
CHUNK_MAX_CHARS=1800
CHUNK_MIN_CHARS=250
CHUNK_OVERLAP_CHARS=150
CHUNK_PREPEND_SECTION_TITLE=true
# "semantic" (quality, slower) or "recursive" (much faster ingestion, no chunk-time embeddings)
CHUNK_STRATEGY=semantic

BATCH_SIZE=32
WORKER_COUNT=1

# LLM generation: "claude" (Anthropic API, default) or "ollama" (offline fallback)
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_MAX_TOKENS=8192
CLAUDE_THINKING=true
CLAUDE_EFFORT=medium

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

RETRIEVER_K=5
HYBRID_SEARCH_ALPHA=0.5
RETRIEVAL_CANDIDATE_MULTIPLIER=4
RRF_K_CONSTANT=60
